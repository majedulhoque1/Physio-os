VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side secrets (DO NOT add a VITE_ prefix — must never reach the browser).
# Set these on the Supabase project for the construction-os-bridge edge function:
#   supabase secrets set PRODUCT_B_ADMIN_SECRET=... SUPER_ADMIN_EMAIL=...
# PRODUCT_B_ADMIN_SECRET — x-admin-secret value for the Construction OS admin bridge
# SUPER_ADMIN_EMAIL      — email of the super admin whose JWT is allowed to call the bridge
